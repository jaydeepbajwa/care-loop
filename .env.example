# Copy to .env and fill in. Everything has a working default for the demo —
# the app runs end-to-end with NO keys set (triage falls back to deterministic rules).

# Postgres (docker-compose provides these defaults)
DATABASE_URL=postgresql+psycopg://careloop:careloop@localhost:5432/careloop

# Optional: enables LLM triage suggestions. Without it, the rules-based
# classifier is used and the demo still works.
ANTHROPIC_API_KEY=

# Claude model used for triage suggestions
TRIAGE_MODEL=claude-opus-4-8

# Structured JSON log level
LOG_LEVEL=INFO
